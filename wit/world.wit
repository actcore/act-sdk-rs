package act:sdk-deps;

// This world is not used to generate bindings — the SDK crates and examples
// declare their own worlds. It exists only as an anchor so `wkg wit fetch`
// (see wkg-registry.toml) knows which act:* packages to resolve and write into
// `wit/deps/`. The fetched deps are committed; the examples symlink to them.
world deps {
  export act:tools/tool-provider@0.2.0;
  export act:sessions/session-provider@0.2.0;
}
